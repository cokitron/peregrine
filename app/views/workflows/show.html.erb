<% content_for(:title) { "#{@workflow.nombre} — Editor" } %>

<div data-controller="workflow-editor"
     data-workflow-editor-update-url-value="<%= @workflow.persisted? ? workflow_path(@workflow, format: :json) : '' %>"
     data-workflow-editor-create-url-value="<%= @workflow.new_record? ? workflows_path(format: :json) : '' %>"
     data-workflow-editor-persisted-value="<%= @workflow.persisted? %>"
     data-workflow-editor-steps-value="<%= (@workflow.drawflow_data["steps"] || []).to_json %>"
     data-workflow-editor-agents-value="<%= @agents.map { |a| { id: a.id, nombre: a.nombre } }.to_json %>"
     data-workflow-editor-workflows-value="<%= (@workflows || []).map { |w| { id: w.id, nombre: w.nombre } }.to_json %>"
     data-workflow-editor-node-states-value="<%= (@workflow.persisted? ? @workflow.workflow_runs.recientes.first&.node_states : nil || {}).to_json %>"
     data-workflow-editor-execute-url-value="<%= @workflow.persisted? ? execute_workflow_path(@workflow, format: :json) : '' %>">

  <%# ── Header ── %>
  <div class="flex items-center justify-between mb-8">
    <div class="flex items-center gap-3">
      <%= link_to workflows_path, class: "text-gris hover:text-grafito", aria: { label: "Back to workflows" } do %>
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      <% end %>
      <input type="text" value="<%= @workflow.nombre %>" id="workflow-nombre"
             data-workflow-editor-target="nombre"
             data-action="blur->workflow-editor#saveNombre"
             aria-label="Workflow name"
             class="text-2xl font-bold bg-transparent border-none focus:outline-none focus:ring-0 text-grafito" />
    </div>

    <div class="flex items-center gap-2">
      <% if @workflow.persisted? %>
        <button data-action="click->workflow-editor#manualSave" class="btn-secondary text-sm">💾 Save</button>
        <button data-action="click->workflow-editor#runWorkflow" class="btn-primary text-sm" data-workflow-editor-target="runBtn">▶ Run</button>
        <button data-action="click->workflow-editor#stopWorkflow" class="btn-secondary text-sm hidden bg-kreoz-red-light text-kreoz-red hover:bg-kreoz-red hover:text-white" data-workflow-editor-target="stopBtn">⏹ Stop</button>
      <% else %>
        <button data-action="click->workflow-editor#createWorkflow" class="btn-primary text-sm">💾 Save</button>
      <% end %>
    </div>
  </div>

  <%# ── Add Step Buttons ── %>
  <div class="flex items-center gap-4 mb-6">
    <div class="flex items-center gap-2">
      <span class="text-sm text-gris font-medium">Add:</span>
      <button data-action="click->workflow-editor#addStep" data-node-type="kiro"  class="btn-sm bg-kreoz-green text-white">⚡ Kiro</button>
      <button data-action="click->workflow-editor#addStep" data-node-type="shell" class="btn-sm bg-kreoz-amber text-grafito">▶ Shell</button>
      <button data-action="click->workflow-editor#addStep" data-node-type="ruby"  class="btn-sm bg-kreoz-purple text-white">◆ Ruby</button>
      <button data-action="click->workflow-editor#addStep" data-node-type="gate"  class="btn-sm bg-kreoz-red text-white">◇ Gate</button>
      <button data-action="click->workflow-editor#addStep" data-node-type="workflow" class="btn-sm bg-blue-600 text-white">🔗 Workflow</button>
    </div>

    <% if @agents.any? %>
      <div class="flex items-center gap-2 border-l border-borde pl-4">
        <span class="text-sm text-gris font-medium">Agent:</span>
        <select data-workflow-editor-target="defaultAgent"
                data-action="change->workflow-editor#saveDefaultAgent"
                class="border border-borde rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:border-kreoz-green">
          <option value="">— None —</option>
          <% @agents.each do |agent| %>
            <option value="<%= agent.id %>" <%= agent.id == @workflow.default_agent_id ? 'selected' : '' %>><%= agent.nombre %></option>
          <% end %>
        </select>
      </div>
    <% end %>
  </div>

  <%# ── Keyboard Hints ── %>
  <div class="flex items-center gap-4 mb-4 text-xs text-gris-claro">
    <span>⌘Z undo</span>
    <span>⌘⇧Z redo</span>
    <span>⌘D duplicate</span>
    <span>⌘↑↓ move</span>
    <span>Esc close</span>
    <span class="border-l border-borde pl-4">Drag from <span class="inline-block w-2.5 h-2.5 rounded-full bg-gris-claro align-middle"></span> port to link nodes</span>
  </div>

  <%# ── Step Cards — Tree-based flow layout ── %>
  <%# Safelist: dynamic classes from workflow_editor_controller.js %>
  <div class="hidden border-t-emerald-600 border-t-amber-500 border-t-purple-600 border-t-red-500 border-t-blue-600 border-l-2 border-emerald-500 border-red-400"></div>
  <div class="relative overflow-x-auto pb-4 min-h-[60vh]" data-workflow-editor-target="canvas">
    <svg data-workflow-editor-target="arrows" class="absolute inset-0 pointer-events-none overflow-visible" aria-hidden="true">
      <defs>
        <marker id="arrow-gray" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto"><path d="M0,0 L8,3 L0,6" fill="#B4B2A9"/></marker>
        <marker id="arrow-green" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto"><path d="M0,0 L8,3 L0,6" fill="#059669"/></marker>
        <marker id="arrow-red" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto"><path d="M0,0 L8,3 L0,6" fill="#E24B4A"/></marker>
      </defs>
    </svg>
    <div data-workflow-editor-target="steps" class="p-4 min-w-max"></div>
  </div>

  <%# ── Run History ── %>
  <% if @workflow.persisted? && @workflow.workflow_runs.any? %>
    <div class="mt-4 pt-4 border-t border-borde">
      <div class="flex items-center justify-between mb-2">
        <h3 class="text-xs font-semibold text-gris uppercase tracking-wide">Recent Runs</h3>
        <%= link_to "View all →", workflow_runs_path(@workflow), class: "text-xs text-kreoz-green hover:underline" %>
      </div>
      <div class="flex items-center gap-4 text-sm text-gris">
        <% @workflow.workflow_runs.recientes.limit(5).each do |run| %>
          <%= link_to workflow_run_path(@workflow, run), class: "flex items-center gap-1 hover:text-grafito" do %>
            <span class="w-2 h-2 rounded-full <%= run_status_dot(run.status) %>"></span>
            <%= run.created_at.strftime("%H:%M") %>
            <% if run.duration %><span class="text-xs">(<%= run.duration.round(1) %>s)</span><% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
