<% content_for(:title) { "Runs — #{@workflow.nombre}" } %>

<div class="w-full max-w-4xl mx-auto">
  <%# ── Header ── %>
  <div class="flex items-center justify-between mb-8">
    <div class="flex items-center gap-3">
      <%= link_to workflow_path(@workflow), class: "text-gris hover:text-grafito" do %>
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      <% end %>
      <h1 class="text-2xl font-bold text-grafito">Runs</h1>
      <span class="text-gris text-sm">— <%= @workflow.nombre %></span>
    </div>
  </div>

  <% if @runs.any? %>
    <div class="space-y-3">
      <% @runs.each do |run| %>
        <%= link_to workflow_run_path(@workflow, run), class: "card p-4 flex items-center gap-4 hover:border-kreoz-green transition-colors block" do %>
          <%# Status indicator %>
          <span class="w-3 h-3 rounded-full shrink-0 <%= run_status_dot(run.status) %>"></span>

          <%# Main info %>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="font-semibold text-sm text-grafito"><%= run.created_at.strftime("%b %d, %Y at %H:%M:%S") %></span>
              <span class="px-2 py-0.5 rounded text-xs font-medium <%= run_status_badge(run.status) %>"><%= run.status.capitalize %></span>
            </div>
            <% if run.input_text.present? %>
              <p class="text-xs text-gris truncate">Input: <%= run.input_text %></p>
            <% end %>
          </div>

          <%# Duration %>
          <div class="text-right shrink-0">
            <% if run.duration %>
              <span class="text-sm font-medium text-grafito"><%= run.duration.round(1) %>s</span>
            <% elsif run.status == "running" %>
              <span class="text-xs text-gris animate-pulse">Running…</span>
            <% else %>
              <span class="text-xs text-gris">—</span>
            <% end %>
          </div>

          <%# Node states summary %>
          <div class="flex items-center gap-1 shrink-0">
            <% (run.node_states || {}).each do |name, state| %>
              <% st = state.is_a?(Hash) ? state["status"] : state %>
              <span class="w-2 h-2 rounded-full <%= run_status_dot(st) %>" title="<%= name %>: <%= st %>"></span>
            <% end %>
          </div>

          <svg class="w-4 h-4 text-gris-claro shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <%= render Kreoz::EmptyStateComponent.new(
      message: "No runs yet. Execute the workflow to see results here."
    ) %>
  <% end %>
</div>
