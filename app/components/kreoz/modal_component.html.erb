<%# Trigger button — render via content block %>
<%= content %>

<%# Modal markup %>
<div id="<%= @id %>" tabindex="-1" aria-hidden="true" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
  <div class="relative p-4 w-full max-w-lg max-h-full">
    <div class="bg-neutral-primary-soft border border-default rounded-base shadow-sm p-4 md:p-6">
      <%# Header %>
      <div class="flex items-center justify-between border-b border-default pb-4">
        <h3 class="text-lg font-semibold text-heading"><%= @title %></h3>
        <button type="button" data-modal-hide="<%= @id %>" class="text-body bg-transparent hover:bg-neutral-tertiary hover:text-heading rounded-base text-sm w-9 h-9 inline-flex justify-center items-center">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 14 14"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
          <span class="sr-only">Cerrar</span>
        </button>
      </div>

      <%# Body %>
      <div class="py-4">
        <% if body? %><%= body %><% end %>
      </div>

      <%# Footer %>
      <% if footer? %>
        <div class="flex items-center border-t border-default space-x-4 pt-4">
          <%= footer %>
        </div>
      <% end %>
    </div>
  </div>
</div>
