<div class="flex items-center">
  <input id="<%= @dom_id %>" name="<%= @name %>" type="checkbox" <%= "checked" if @checked %> <%= "disabled" if @disabled %> class="w-4 h-4 border border-default-medium rounded-xs bg-neutral-secondary-medium focus:ring-2 focus:ring-brand-soft <%= "disabled:cursor-not-allowed disabled:opacity-50" if @disabled %>" <%= tag.attributes(@html_options) %>>
  <label for="<%= @dom_id %>" class="ms-2 text-sm font-medium text-heading <%= "opacity-50" if @disabled %>"><%= @label %></label>
</div>
