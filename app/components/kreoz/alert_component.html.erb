<div id="<%= @dom_id %>" class="flex items-center p-4 text-sm rounded-lg border-l-4 <%= @styles[:bg] %> <%= @styles[:text] %> <%= @styles[:border] %>" role="alert">
  <svg class="w-4 h-4 me-2 shrink-0 <%= @styles[:icon_color] %>" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 11h2v5m-2 0h4m-2.592-8.5h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
  </svg>
  <p class="flex-1"><%= @message %></p>
  <% if dismissible? %>
    <button type="button"
      class="ms-auto -mx-1.5 -my-1.5 rounded-lg p-1.5 inline-flex items-center justify-center h-8 w-8 shrink-0 hover:opacity-75"
      data-dismiss-target="#<%= @dom_id %>"
      aria-label="Cerrar">
      <span class="sr-only">Cerrar</span>
      <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 17.94 6M18 18 6.06 6"/>
      </svg>
    </button>
  <% end %>
</div>
